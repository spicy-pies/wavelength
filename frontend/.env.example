# Backend base URL — used for WebSocket and API proxy (no trailing slash)
NEXT_PUBLIC_WS_URL=http://localhost:3001

# Supabase Auth (Dashboard: Project Settings → API → URL + anon key)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Groq — interest suggestions (API route only)
# GROQ_API_KEY=

# Google Gemini — embeddings for user_embeddings (API route only; gemini-embedding-001, 1536 dims for pgvector)
# GEMINI_API_KEY=

# Google Maps JavaScript API — for Discover map (enable Maps JavaScript API in Cloud Console)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
